# Dpsk - Configuration Example
# Renommez ce fichier en config.yaml et remplissez vos clés.

watchlist:
- BTC/USDT
#- ETH/USDT
- HYPE/USDT:USDT
- XRP/USDT
#- LINK/USDT
#- BNB/USDT
#- SOL/USDT
- VET/USDT

timeframe: 4h
candles_limit: 500
cache_ttl_minutes: 240
max_retries: 3
retry_delay_seconds: 5
request_pause: 0.3

# Paramètres des indicateurs (Module 2)
ema_fast: 20
ema_mid: 50
ema_slow: 200
atr_period: 10
rsi_period: 14
kc_ema_period: 20
kc_atr_period: 10
kc_mult: 2.0
vol_ma_period: 20
vol_surge_mult: 1.8
adx_period: 14
daily_trend_strict: false

# Paramètres du Module 3 (détection de signal)
signal:
  cooldown_minutes: 15
  daily_filter_enabled: true
  adx_required: true
  adx_threshold: 20
  fibo_proximity_atr_mult: 0.5
  fibo_proximity_pct_max: 0.6
  kc_filter: true
  min_confluences: 3
  min_confluences_no_struct: 4
  min_pivots: 4
  min_swing_diff_pct: 0.5
  rsi_long_zone: [30, 45]
  rsi_short_zone: [55, 70]
  sl_atr_mult: 1.0
  tp1_rr: 1.2
  tp2_rr: 2.0
  zigzag_window: 3

# --- SECRETS (À remplir dans votre config.yaml local) ---
telegram:
  token: "VOTRE_BOT_TOKEN"
  chat_id: "VOTRE_CHAT_ID"
  allowed_user_id: "VOTRE_USER_ID"
  heartbeat_minutes: 300  # Heartbeat toutes les 5h (0 = désactivé)

# ⚠️ MIGRATION : ancienne section "binance_testnet"
# Clés API à générer sur : https://testnet.binancefutures.com
binance_testnet:
  api_key: "VOTRE_API_KEY_FUTURES_DEMO"
  api_secret: "VOTRE_API_SECRET_FUTURES_DEMO"
  demo: true          # ← remplace 'testnet: true'

risk:
  leverage: 5         # Levier futures (1 = pas de levier)
  risk_per_trade: 1.0
  max_positions: 3
  max_exposure: 50.0
  daily_loss_limit: -5.0
  trailing_sl_enabled: true
  trailing_sl_activation_tp: 1
  trailing_sl_atr_mult: 2.0
  trailing_sl_callback_rate: 1.0
  dynamic_sizing_adx: true
  max_position_size_pct: 1.0   # Plafond notionnel par trade (% du capital live)
  safety_margin_pct: 5.0        # Marge de sécurité pour frais/slippage/réserves Binance

execution:
  spot_only: false    # false = futures LONG + SHORT activés
  auto_execute: true